# ─── 运行环境 ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Authing 鉴权 ─────────────────────────────────────────────────
# 在 Authing 控制台「应用」→「应用配置」中获取
AUTHING_APP_ID=your_authing_app_id
# 格式：https://your-app.authing.cn  （末尾不带斜杠）
AUTHING_APP_HOST=https://your-app.authing.cn

# ─── 数据库（阿里云 ApsaraDB RDS for PostgreSQL）─────────────────
# 格式：postgres://user:password@host:5432/dbname
# 内网访问（VPC 内推荐）：postgres://user:pass@rm-xxx.pg.rds.aliyuncs.com:5432/quickai
DATABASE_URL=postgres://user:password@your-rds-host:5432/quickai

# 是否关闭 SSL（内网 VPC 访问可设为 false；公网访问保留默认 true）
# DB_SSL=false

# ─── 阿里云 OSS ────────────────────────────────────────────────────
OSS_REGION=oss-cn-hangzhou
# 内网端点（ECS 同区推荐，节省流量费）：oss-cn-hangzhou-internal.aliyuncs.com
# 公网端点：oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
# CDN 或公网访问域名（可选，不填则自动拼接 bucket+endpoint）
# OSS_BASE_URL=https://cdn.your-domain.com

# ─── 图片 Provider（Nano Banana 2 / 兼容聚合接口）────────────────
IMAGE_PROVIDER_KEY=your_image_provider_key
IMAGE_PROVIDER_BASE_URL=https://api.nano-banana.com/v1
IMAGE_PROVIDER_MODEL=nano-banana-2

# ─── 视频 Provider（Sora2 / 兼容聚合接口）───────────────────────
SORA_API_KEY=7c15e5bd8e3bc5d9ba8127986f6c7086debd6f9b4e5da25e789abc01a42278bd
SORA_BASE_URL=https://www.aimh8.com/agent/openapi/fpbrowser2api

# ─── 安全与日志 ────────────────────────────────────────────────────
# 允许的前端来源（多个用逗号分隔）
ALLOWED_ORIGINS=https://your-domain.com

# 日志目录（容器内路径，映射到持久化卷）
LOG_DIR=/app/logs

# 日志级别：error / warn / info / http / debug
LOG_LEVEL=info

# 应用公网地址（用于生成回调 URL 等）
APP_BASE_URL=https://your-domain.com
