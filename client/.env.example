# ─── Authing 鉴权 ─────────────────────────────────────────────────
# 在 Authing 控制台「应用」→「应用配置」中获取
VITE_AUTHING_APP_ID=your_authing_app_id
VITE_AUTHING_DOMAIN=https://your-app.authing.cn

# 登录成功后 Authing 回调到此地址（需要在 Authing 控制台「登录回调 URL」中配置相同地址）
# 开发环境：http://localhost:5173/callback
# 生产环境：https://your-domain.com/callback
VITE_AUTHING_REDIRECT_URI=http://localhost:5173/callback

# 登出后跳转地址（需要在 Authing 控制台「登出回调 URL」中配置）
VITE_AUTHING_LOGOUT_URI=http://localhost:5173/

# ─── API 地址 ──────────────────────────────────────────────────────
# 开发环境：http://localhost:5000
# 生产环境：留空（Nginx 反向代理 /api，使用相对路径）
VITE_BASE_URL=http://localhost:5000
